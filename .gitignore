# ─── Ambiente virtual (não versionar — é específico de cada máquina) ───
.venv/
venv/
env/

# ─── Caches Python ───
__pycache__/
*.py[cod]
*.egg-info/

# ─── Dados e saídas geradas pelos scripts (grandes / regeneráveis) ───
# O corpus completo passa de 100 MB — acima do limite do GitHub.
# Para versionar dados grandes, use Git LFS ou os "Releases" do GitHub.
Mestrado_PETR4/
*.csv
*.log
*.png

# ─── Documentos e artefatos gerados (regeneráveis pelos scripts) ───
*.docx
*.pdf
_doc_assets/

# ─── Material de pesquisa (artigos, PDFs, exame) — não versionar ───
Referencial_Teorico/
Exame_qualificacao/

# ─── Sistema operacional / editores ───
.DS_Store
Thumbs.db
.vscode/
.idea/
