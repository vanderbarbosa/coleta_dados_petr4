	url = {https://linkinghub.elsevier.com/retrieve/pii/S0957417416307187},
	doi = {10.1016/j.eswa.2016.12.036},
	abstract = {In this paper, we propose a robust methodology to assess the value of microblogging data to forecast stock market variables: returns, volatility and trading volume of diverse indices and portfolios. The methodology uses sentiment and attention indicators extracted from microblogs (a large Twitter dataset is adopted) and survey indices (AAII and II, USMC and Sentix), diverse forms to daily aggregate these indicators, usage of a Kalman Filter to merge microblog and survey sources, a realistic rolling windows evaluation, several Machine Learning methods and the Diebold-Mariano test to validate if the sentiment and attention based predictions are valuable when compared with an autoregressive baseline. We found that Twitter sentiment and posting volume were relevant for the forecasting of returns of S\&P 500 index, portfolios of lower market capitalization and some industries. Additionally, KF sentiment was informative for the forecasting of returns. Moreover, Twitter and KF sentiment indicators were useful for the prediction of some survey sentiment indicators. These results conﬁrm the usefulness of microblogging data for ﬁnancial expert systems, allowing to predict stock market behavior and providing a valuable alternative for existing survey measures with advantages (e.g., fast and cheap creation, daily frequency).},
	language = {en},
	urldate = {2026-04-03},
	journal = {Expert Systems with Applications},
	author = {Oliveira, Nuno and Cortez, Paulo and Areal, Nelson},
	month = may,
	year = {2017},
	pages = {125--144},
	file = {PDF:C\:\\Users\\Vanderlei\\Zotero\\storage\\RCPYBE5E\\Oliveira et al. - 2017 - The impact of microblogging data for stock market prediction Using Twitter to predict returns, vola.pdf:application/pdf},
}

